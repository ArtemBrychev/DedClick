<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Заголовок -->
        <TextView
            android:id="@+id/title_top"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:text="Здравствуй, пользователь!"
            android:textSize="20sp"
            android:textColor="#334155"
            android:gravity="center"
            android:layout_marginTop="32dp" />

        <!-- Первая карточка -->
        <LinearLayout
            android:id="@+id/signal_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/title_top"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:background="@drawable/bg_button_green_28"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Всё в порядке"
                android:textSize="28sp"
                android:textColor="#FFFFFF"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Нажмите, чтобы отправить уведомление\nвсем доверенным лицам."
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:gravity="center" />
        </LinearLayout>

        <!-- Вторая карточка -->
        <LinearLayout
            android:id="@+id/trusted_list_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/signal_button"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:background="@drawable/bg_button_light_28"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Доверенные лица"
                android:textSize="28sp"
                android:textColor="#0F172A"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Просмотр списка, добавление и\nудаление контактов."
                android:textSize="14sp"
                android:textColor="#0F172A"
                android:gravity="center" />
        </LinearLayout>

        <!-- Последний сигнал -->
        <LinearLayout
            android:id="@+id/card_last_signal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/trusted_list_button"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:background="@drawable/bg_last_signal"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Последний сигнал был отправлен\nсегодня в 09:42"
                android:textSize="14sp"
                android:textColor="#065F46"
                android:gravity="center" />
        </LinearLayout>


        <!-- КНОПКА ВЫХОДА ИЗ АККАУНТА ТОЛЬКО НА ВРЕМЯ  РАЗРАБОТКИ-->
        <LinearLayout
            android:id="@+id/logout_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/card_last_signal"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:background="@drawable/ic_delete_cross"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Выйти из аккаунта"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:gravity="center" />
        </LinearLayout>

    </RelativeLayout>
</ScrollView>
