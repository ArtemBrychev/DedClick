<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fillViewport="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Кнопка назад -->
        <ImageView
            android:id="@+id/priveous_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_card_grey"
            android:src="@drawable/arrow_back"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:layout_marginTop="20dp"/>

        <!-- Заголовок -->
        <TextView
            android:id="@+id/title_code"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/priveous_button"
            android:layout_marginTop="32dp"
            android:text="Введите код"
            android:textSize="24sp"
            android:textColor="#0F172A" />

        <!-- Подзаголовок -->
        <TextView
            android:id="@+id/subtitle_code"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/title_code"
            android:layout_marginTop="12dp"
            android:text="Мы отправили код в СМС на номер +7 *** --34"
            android:textSize="16sp"
            android:textColor="#000000"
            android:lineSpacingExtra="4sp" />

        <!-- Контейнер для 4 квадратиков -->
        <LinearLayout
            android:id="@+id/code_boxes_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/subtitle_code"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- 4 одинаковых квадрата -->
            <FrameLayout
                android:id="@+id/box1"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_button_light_20"
                android:layout_marginRight="16dp" />

            <FrameLayout
                android:id="@+id/box2"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_button_light_20"
                android:layout_marginRight="16dp" />

            <FrameLayout
                android:id="@+id/box3"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_button_light_20"
                android:layout_marginRight="16dp" />

            <FrameLayout
                android:id="@+id/box4"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_button_light_20" />
        </LinearLayout>

        <!-- Невидимый EditText для ввода -->
        <EditText
            android:id="@+id/hidden_code_input"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:inputType="number"
            android:maxLength="4"
            android:alpha="0"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:cursorVisible="false"
            android:textColor="@android:color/transparent" />

        <!-- Кнопка подтвердить -->
        <LinearLayout
            android:id="@+id/confirm_button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_below="@id/code_boxes_container"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_button_green_20"
            android:gravity="center">

            <TextView
                android:id="@+id/accept_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Подтвердить"
                android:textSize="22sp"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- Текст "Отправить код ещё раз" -->
        <TextView
            android:id="@+id/resend_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/confirm_button"
            android:layout_marginTop="24dp"
            android:layout_centerHorizontal="true"
            android:text="Отправить код ещё раз через 00:30"
            android:textSize="14sp"
            android:textColor="#64748B" />

    </RelativeLayout>
</ScrollView>
