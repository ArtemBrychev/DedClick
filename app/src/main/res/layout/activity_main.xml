<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Верхняя карточка -->
        <LinearLayout
            android:id="@+id/card_top"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:gravity="center">

            <!-- Круглый фон с логотипом -->
            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_circle"/>

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/pd_logo"
                    android:scaleType="centerInside"/>
            </FrameLayout>

            <!-- Заголовок -->
            <TextView
                android:id="@+id/title_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Предохронитель\nдеда"
                android:textSize="28sp"
                android:textColor="#0F172A"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Нижние кнопки / прямоугольники -->
        <LinearLayout
            android:id="@+id/buttons_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_below="@id/card_top"
            android:layout_marginTop="132dp"
            android:gravity="center"
            android:spacing="16dp">

            <!-- Тёмная кнопка -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_button_dark"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Войти"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <!-- Светлая кнопка -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_button_light"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Зарегистрироваться"
                    android:textSize="20sp"
                    android:textColor="#0F172A"/>
            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>
</ScrollView>